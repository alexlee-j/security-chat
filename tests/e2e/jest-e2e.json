{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e.spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../../apps/backend/src/$1"
  },
  "testTimeout": 30000,
  "forceExit": true,
  "detectOpenHandles": false,
  "runInBand": true
}
