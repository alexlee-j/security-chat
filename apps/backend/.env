NODE_ENV=development
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=security_chat_user
DB_PASSWORD=security_chat_pass_please_change
DB_NAME=security_chat
DB_SYNC=true

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass_please_change

