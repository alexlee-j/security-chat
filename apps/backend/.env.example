NODE_ENV=development
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=security_chat_user
DB_PASSWORD=security_chat_pass_please_change
DB_NAME=security_chat
DB_SYNC=true

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

MEDIA_ROOT=/tmp/security-chat-media
MEDIA_MAX_BYTES=104857600

JWT_SECRET=dev_secret_change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

SEC_LOGIN_MAX_ATTEMPTS=5
SEC_LOGIN_FAIL_WINDOW_SEC=300
LOG_HTTP=1

# SMTP 配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=example@qq.com
SMTP_PASS=smtp_password
SMTP_FROM=Security Chat <example@qq.com>
SMTP_SECURE=false
SMTP_TLS=true