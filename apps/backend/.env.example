# 后端环境变量示例文件
# 此文件仅包含变量名和说明，无真实值，必须推送到仓库

# ==================== 时区配置 ====================
TZ=Asia/Shanghai

# ==================== 数据库配置 ====================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=security_chat_user
DB_PASSWORD=
DB_NAME=security_chat
DB_POOL_SIZE=20
DB_MAX_QUERY_TIME=2000
DB_CONNECT_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000
# ⚠️ 生产环境必须设为 false！使用 migrations 管理 schema 变更
DB_SYNC=false
# 自动运行 pending migrations（部署时设为 true）
DB_RUN_MIGRATIONS=false

# ==================== Redis 配置 ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT 配置 ====================
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==================== 应用配置 ====================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
LOG_HTTP=1

# ==================== 邮件配置（可选） ====================
# 开发环境可使用 QQ 邮箱
# SMTP 服务器: smtp.qq.com
# SMTP 端口: 587 (TLS) 或 465 (SSL)
# 授权码获取: QQ邮箱设置 → 账户 → POP3/SMTP服务 → 生成授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_qq_email@qq.com
SMTP_PASS=your授权码
SMTP_FROM=Security Chat <your_qq_email@qq.com>
SMTP_SECURE=false
SMTP_TLS=true

# ==================== 媒体文件配置 ====================
MEDIA_ROOT=/tmp/security-chat-media
MEDIA_MAX_BYTES=104857600

# ==================== 安全配置 ====================
SEC_LOGIN_FAIL_WINDOW_SEC=300
SEC_LOGIN_MAX_ATTEMPTS=5
AUTH_CODE_DEBUG_RETURN=false

# ==================== CORS 配置 ====================
# 逗号分隔，用于 CORS 配置和 CSP 策略
CORS_ALLOWED_ORIGINS=

# ==================== Tauri 配置 ====================
# CSP 例外域名（逗号分隔）
TAURI_CSP_DOMAINS=http://localhost:* http://127.0.0.1:*
# 异常域名
TAURI_EXCEPTION_DOMAIN=
# 更新端点
TAURI_UPDATER_ENDPOINT=
# 更新公钥（生产环境）
TAURI_UPDATER_PUBKEY=
