//! libsignal-protocol Store 使用官方的 InMemSignalProtocolStore
//! Week 4 紧急修复 V2：使用正确的 API

use libsignal_protocol::{
    InMemSignalProtocolStore,
    IdentityKeyPair,
    ProtocolAddress,
    SessionRecord,
    PreKeyRecord,
    SignedPreKeyRecord,
    KyberPreKeyRecord,
    SignalProtocolError,
    PreKeyId,
    SignedPreKeyId,
    KyberPreKeyId,
    DeviceId,
    KeyPair,
    kem,
    Timestamp,
    // trait 直接导出
    IdentityKeyStore,
    PreKeyStore,
    SignedPreKeyStore,
    KyberPreKeyStore,
    SessionStore,
    GenericSignedPreKey,
    GenericKyberPreKey,
};
use std::sync::Arc;
use tokio::sync::RwLock;
use rand::rngs::OsRng;
use std::time::SystemTime;

/// 应用状态 - 使用官方的内存 Store
pub type AppStore = Arc<RwLock<InMemSignalProtocolStore>>;

/// 创建新的 Store
pub fn create_store() -> Result<AppStore, SignalProtocolError> {
    let mut rng = OsRng;
    
    // 生成身份密钥对
    let identity_key_pair = IdentityKeyPair::generate(&mut rng);
    
    // 生成注册 ID
    let registration_id: u8 = rng.gen_range(0..16384);
    
    // 创建内存 Store
    let store = InMemSignalProtocolStore::new(identity_key_pair, registration_id as u32)?;
    
    Ok(Arc::new(RwLock::new(store)))
}

/// 初始化 Store（生成预密钥）- Week 4 紧急修复 V2
pub async fn initialize_store(store: &AppStore) -> Result<(), SignalProtocolError> {
    let mut rng = OsRng;
    let mut store = store.write().await;
    
    // 生成 100 个预密钥
    for i in 1..=100 {
        let pre_key_id = PreKeyId::from(i);
        let key_pair = KeyPair::generate(&mut rng);
        let pre_key_record = PreKeyRecord::new(pre_key_id, &key_pair);
        PreKeyStore::save_pre_key(&mut *store, pre_key_id, &pre_key_record).await?;
    }
    
    // 生成签名预密钥 - 使用 GenericSignedPreKey::new
    let signed_pre_key_id = SignedPreKeyId::from(1);
    let identity_key_pair: IdentityKeyPair = IdentityKeyStore::get_identity_key_pair(&*store).await?;
    let key_pair: KeyPair = KeyPair::generate(&mut rng);
    let signature = identity_key_pair.private_key()
        .calculate_signature(&key_pair.public_key, &mut rng)?;
    let signed_pre_key_record = <SignedPreKeyRecord as GenericSignedPreKey>::new(
        signed_pre_key_id,
        Timestamp::from_epoch_millis(SystemTime::now().duration_since(SystemTime::UNIX_EPOCH).unwrap().as_millis() as u64),
        &key_pair,
        &signature,
    );
    SignedPreKeyStore::save_signed_pre_key(&mut *store, signed_pre_key_id, &signed_pre_key_record).await?;
    
    // 生成 Kyber 预密钥 - 使用 GenericKyberPreKey::new
    let kyber_pre_key_id = KyberPreKeyId::from(1);
    let kem_keypair: kem::KeyPair = kem::KeyPair::generate(kem::KeyType::Kyber1024, &mut rng);
    let signature = identity_key_pair.private_key()
        .calculate_signature(&kem_keypair.public_key, &mut rng)?;
    let kyber_pre_key_record = <KyberPreKeyRecord as GenericKyberPreKey>::new(
        kyber_pre_key_id,
        Timestamp::from_epoch_millis(SystemTime::now().duration_since(SystemTime::UNIX_EPOCH).unwrap().as_millis() as u64),
        &kem_keypair,
        &signature,
    );
    KyberPreKeyStore::save_kyber_pre_key(&mut *store, kyber_pre_key_id, &kyber_pre_key_record).await?;
    
    Ok(())
}

/// 获取预密钥包 - Week 4 紧急修复 V2
pub async fn get_prekey_bundle(store: &AppStore) -> Result<libsignal_protocol::PreKeyBundle, SignalProtocolError> {
    let store = store.read().await;
    
    // 获取身份密钥
    let identity_key_pair: IdentityKeyPair = IdentityKeyStore::get_identity_key_pair(&*store).await?;
    
    // 获取第一个可用的预密钥
    let pre_key_id: PreKeyId = store.all_pre_key_ids().next()
        .ok_or(SignalProtocolError::InvalidPreKeyId)?;
    let pre_key_record: PreKeyRecord = PreKeyStore::get_pre_key(&*store, pre_key_id).await?;
    
    // 获取签名预密钥
    let signed_pre_key_id = SignedPreKeyId::from(1);
    let signed_pre_key_record: SignedPreKeyRecord = SignedPreKeyStore::get_signed_pre_key(&*store, signed_pre_key_id).await?;
    
    // 获取 Kyber 预密钥
    let kyber_pre_key_id = KyberPreKeyId::from(1);
    let kyber_pre_key_record: KyberPreKeyRecord = KyberPreKeyStore::get_kyber_pre_key(&*store, kyber_pre_key_id).await?;
    
    // 构造预密钥包
    let mut rng = OsRng;
    let device_id: DeviceId = DeviceId::new(rng.gen_range(1..16384))
        .map_err(|_| SignalProtocolError::InvalidArgument("Invalid device ID".to_string()))?;
    
    let bundle = libsignal_protocol::PreKeyBundle::new(
        IdentityKeyStore::get_local_registration_id(&*store).await?,
        device_id,
        Some((pre_key_id, pre_key_record.key_pair().public_key)),
        signed_pre_key_id,
        signed_pre_key_record.key_pair().public_key,
        signed_pre_key_record.signature().to_vec(),
        kyber_pre_key_id,
        kyber_pre_key_record.key_pair().public_key,
        kyber_pre_key_record.signature().to_vec(),
        *identity_key_pair.identity_key(),
    )?;
    
    Ok(bundle)
}

/// 获取会话
pub async fn get_session(store: &AppStore, address: &ProtocolAddress) -> Result<Option<SessionRecord>, SignalProtocolError> {
    let store = store.read().await;
    SessionStore::load_session(&*store, address).await
}

/// 保存会话
pub async fn save_session(store: &AppStore, address: &ProtocolAddress, record: &SessionRecord) -> Result<(), SignalProtocolError> {
    let mut store = store.write().await;
    SessionStore::store_session(&mut *store, address, record.clone()).await
}
