//! 消息加密与解密 - Week 4 紧急修复
//! 使用官方正确的 API

use libsignal_protocol::{
    ProtocolAddress,
    message_encrypt,
    message_decrypt,
    CiphertextMessage,
    PreKeySignalMessage,
    SignalMessage,
};
use rand::rngs::OsRng;
use crate::signal::store::AppStore;
use std::time::SystemTime;

/// 加密的消息
#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub struct EncryptedMessage {
    pub message_type: u32,
    pub body: String,
}

/// 加密消息 - Week 4 紧急修复：使用正确的 6 参数 API
pub async fn encrypt_message(
    store: &AppStore,
    address: &ProtocolAddress,
    plaintext: &[u8],
) -> Result<EncryptedMessage, libsignal_protocol::SignalProtocolError> {
    let mut rng = OsRng;

    let mut store = store.write().await;
    
    // 官方正确 API：6 个参数
    let ciphertext = message_encrypt(
        plaintext,
        address,
        &mut *store,  // session_store
        &mut *store,  // identity_store
        SystemTime::now(),
        &mut rng,
    ).await?;

    let (message_type, body) = match ciphertext {
        CiphertextMessage::PreKeySignalMessage(msg) => {
            // 官方正确序列化：使用 encode()
            let mut buf = Vec::new();
            msg.encode(&mut buf)?;
            (1, base64::encode(buf))
        }
        CiphertextMessage::SignalMessage(msg) => {
            let mut buf = Vec::new();
            msg.encode(&mut buf)?;
            (2, base64::encode(buf))
        }
        _ => return Err(libsignal_protocol::SignalProtocolError::InvalidMessage(
            libsignal_protocol::CiphertextMessageType::Whisper,
            "Unknown message type"
        )),
    };

    Ok(EncryptedMessage {
        message_type,
        body,
    })
}

/// 解密消息 - Week 4 紧急修复：使用正确的 decode 静态方法
pub async fn decrypt_message(
    store: &AppStore,
    address: &ProtocolAddress,
    encrypted: &EncryptedMessage,
) -> Result<Vec<u8>, libsignal_protocol::SignalProtocolError> {
    let ciphertext = base64::decode(&encrypted.body)
        .map_err(|_| libsignal_protocol::SignalProtocolError::InvalidMessage(
            libsignal_protocol::CiphertextMessageType::Whisper,
            "Invalid base64"
        ))?;

    let mut rng = OsRng;
    let mut store = store.write().await;

    let plaintext = match encrypted.message_type {
        1 => {
            // 官方正确 API：使用静态方法 decode()
            let msg = PreKeySignalMessage::decode(&ciphertext)?;
            message_decrypt(
                &msg,
                address,
                &mut *store,
                &mut *store,
                &mut *store,
                &mut *store,
                &mut *store,
                &mut rng,
            ).await?
        }
        2 => {
            // 官方正确 API：使用静态方法 decode()
            let msg = SignalMessage::decode(&ciphertext)?;
            message_decrypt(
                &msg,
                address,
                &mut *store,
                &mut *store,
                &mut *store,
                &mut *store,
                &mut *store,
                &mut rng,
            ).await?
        }
        _ => return Err(libsignal_protocol::SignalProtocolError::InvalidMessage(
            libsignal_protocol::CiphertextMessageType::Whisper,
            "Unknown message type"
        )),
    };

    Ok(plaintext)
}

#[cfg(test)]
mod tests {
    use super::*;
    use crate::signal::store::{create_store, initialize_store};

    #[tokio::test]
    async fn test_encrypt_decrypt_roundtrip() {
        // 创建存储
        let store = create_store().unwrap();
        initialize_store(&store).await.unwrap();

        let address = ProtocolAddress::new("test_recipient".to_string(), 1);
        let plaintext = b"Hello, Signal!";

        // 加密
        let encrypted = encrypt_message(&store, &address, plaintext).await.unwrap();

        // 解密
        let decrypted = decrypt_message(&store, &address, &encrypted).await.unwrap();

        // 验证
        assert_eq!(plaintext, &decrypted[..]);
    }
}
