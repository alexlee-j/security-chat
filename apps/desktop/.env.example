# 桌面应用环境变量模板
# 此文件仅包含变量名和说明，必须推送到仓库
# 实际使用请复制为 .env 并填入真实值

# ==================== API 配置 ====================
# 后端 API 地址
# 开发环境: http://localhost:3000/api/v1
# 生产环境: https://silencelee.cn/api/v1
VITE_API_URL=

# ==================== 应用配置 ====================
# 应用名称
VITE_APP_NAME=Security Chat

# ==================== Tauri 配置 ====================
# 更新端点（生产环境）
VITE_TAURI_UPDATER_ENDPOINT=
