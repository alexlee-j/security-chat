# 桌面应用开发环境配置文件
# 此文件包含开发环境的安全默认值，可以推送到仓库

# ==================== API 配置 ====================
# 后端 API 地址
VITE_API_URL=http://127.0.0.1:3000/api/v1

# ==================== 应用配置 ====================
# 应用名称
VITE_APP_NAME=Security Chat

# ==================== Tauri 配置 ====================
# 更新端点（开发环境）
VITE_TAURI_UPDATER_ENDPOINT=
