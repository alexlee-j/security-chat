# Security Chat 生产环境配置文件
# 复制此文件为 .env.production 并修改对应值

# ==================== 数据库配置 ====================
DB_USER=security_chat_user
DB_PASSWORD=your_secure_password_here
DB_NAME=security_chat

# ==================== Redis 配置 ====================
REDIS_PASSWORD=your_redis_password_here

# ==================== MinIO 配置 ====================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here

# ==================== JWT 配置 ====================
# 生成命令: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# ==================== CORS 配置 ====================
# 生产环境允许的域名（逗号分隔）
CORS_ALLOWED_ORIGINS=https://www.silencelee.cn,https://silencelee.cn

# ==================== 日志配置 ====================
LOG_LEVEL=warn
LOG_HTTP=1

# ==================== 镜像标签 ====================
# IMAGE_TAG=latest

# ==================== 邮件配置 ====================
# 生产环境使用 QQ 邮箱
# SMTP 服务器: smtp.qq.com
# SMTP 端口: 587 (TLS) 或 465 (SSL)
# 授权码获取: QQ邮箱设置 → 账户 → POP3/SMTP服务 → 生成授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_qq_email@qq.com
SMTP_PASS=your授权码
SMTP_FROM=Security Chat <your_qq_email@qq.com>
SMTP_SECURE=false
SMTP_TLS=true
